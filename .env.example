# ============================================================
# 環境変数サンプルファイル
# ------------------------------------------------------------
# このファイルをコピーして .env.local を作成し、各値を設定してください。
#   cp .env.example .env.local
#
# .env.local は .gitignore により Git 管理対象外です。
# 実際のシークレット値をこのファイルに直接書かないでください。
# ============================================================

# ------------------------------------------------------------
# Better Auth — 認証ライブラリの設定
# ------------------------------------------------------------

# セッション署名・暗号化に使用するシークレットキー
# 以下のコマンドでランダムな値を生成できます:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# アプリケーションのベース URL（認証コールバックの構築に使用）
# 開発環境: http://localhost:3000
# 本番環境: デプロイ先の URL に変更してください
BETTER_AUTH_URL=http://localhost:3000

# クライアントサイド（ブラウザ）から参照するベース URL
# BETTER_AUTH_URL と同じ値で問題ありません
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# Google OAuth — Google ログインの設定
# ------------------------------------------------------------
# Google Cloud Console (https://console.cloud.google.com/) で
# OAuth 2.0 クライアント ID を作成して取得してください。
#
# 作成手順:
#   1. Google Cloud Console でプロジェクトを作成（または既存を選択）
#   2. 「APIとサービス」→「認証情報」→「認証情報を作成」
#   3. 「OAuth 2.0 クライアント ID」を選択、種類は「ウェブアプリケーション」
#   4. 承認済みのリダイレクト URI に以下を追加:
#        http://localhost:3000/api/auth/callback/google
#   5. 発行された Client ID と Client Secret を以下に貼り付ける

# Google OAuth クライアント ID
GOOGLE_CLIENT_ID=

# Google OAuth クライアントシークレット
GOOGLE_CLIENT_SECRET=
